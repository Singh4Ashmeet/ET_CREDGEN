# LLM Configuration
LLM_PROVIDER=gemini
LLM_MODE=disabled
LLM_SYSTEM_PROMPT="You are CredGen AI, an intelligent loan assistant for Indian users."

# API Keys
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# App Security
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin@123
SEED_ADMIN_EMAIL=admin@credgen.in
APP_SECRET_KEY=credgen-secret-key-change-in-production
JWT_SECRET_KEY="credgen-jwt-secret"
DATABASE_URL="sqlite:///credgen_test.db"
ALLOWED_ORIGINS="http://localhost:5000"
FLASK_USE_RELOADER=false

# path for tesseract and poppler
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
POPPLER_PATH=C:\poppler\Library\bin
